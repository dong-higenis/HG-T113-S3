bootdelay=5

kernel_addr_r=0x42000000
fdt_addr_r=0x43000000

mmcdev=0
bootpart=1

kernel_file=zImage
fdt_file=hg-t113s3-kit.dtb

sd_root=/dev/mmcblk0p2

boot_sd=
    echo Booting Linux from SD card;
    mmc dev ${mmcdev} &&
    mmc rescan &&
    fatload mmc ${mmcdev}:${bootpart} ${kernel_addr_r} ${kernel_file} &&
    fatload mmc ${mmcdev}:${bootpart} ${fdt_addr_r} ${fdt_file} &&
    setenv bootargs console=ttyS0,115200 root=${sd_root} rootfstype=ext4 rootwait rw &&
    bootz ${kernel_addr_r} - ${fdt_addr_r}

bootcmd=run boot_sd