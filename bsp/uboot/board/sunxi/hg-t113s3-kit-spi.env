bootdelay=5

kernel_addr_r=0x42000000
fdt_addr_r=0x43000000

spi_kernel_off=0x00100000
spi_kernel_size=0x00800000

spi_fdt_off=0x00900000
spi_fdt_size=0x00020000

spi_root=/dev/mtdblock3

boot_spi=
    echo Booting Linux from SPI NOR;
    sf probe &&
    sf read ${kernel_addr_r} ${spi_kernel_off} ${spi_kernel_size} &&
    sf read ${fdt_addr_r} ${spi_fdt_off} ${spi_fdt_size} &&
    setenv bootargs console=ttyS0,115200 root=${spi_root} rootfstype=squashfs ro &&
    bootz ${kernel_addr_r} - ${fdt_addr_r}

bootcmd=run boot_spi